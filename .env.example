# ── Required: GenLayer ReptileRPG contract ────────────────────────────────────
# Deployed contract address on Bradbury testnet.
VITE_REPTILE_RPG_ADDRESS=0x_REPLACE_WITH_DEPLOYED_CONTRACT_ADDRESS

# ── Required: Burner wallet (browser signer) ──────────────────────────────────
# WARNING: This key is intentionally bundled into the client JS build.
# It MUST be a dedicated throwaway testnet wallet with zero real value.
# Never use a mainnet key or any key holding real funds here.
VITE_PLAYER_PRIVATE_KEY=0x_REPLACE_WITH_BURNER_KEY_LATER

# ── Required for scripts/set_burner.mjs only ─────────────────────────────────
# Deployer/owner private key — used once off-browser to call set_burner() on the contract.
# Never commit this key. Only used by: node scripts/set_burner.mjs
DEPLOYER_PRIVATE_KEY=0x_REPLACE_WITH_DEPLOYER_KEY_FOR_SETUP_ONLY

# ── Optional: HuntOracle contract (deploy with: npm run deploy-contracts) ────
# Provides live threat_level and dynamic batch_multiplier to the frontend.
VITE_HUNT_ORACLE_ADDRESS=

# ── Optional: DragonLore contract (deploy with: npm run deploy-contracts) ────
# Provides AI-generated chronicle text to the HUD ticker.
VITE_DRAGON_LORE_ADDRESS=
